# CO Discord Bot — environment template
# Copy to .env and fill in. Secrets (tokens / API keys) must be unique
# per deployment — never commit them.

# ── Discord (required) ─────────────────────────────────────────
DISCORD_BOT_TOKEN=          # bot token from the Discord developer portal
DISCORD_TOKEN=              # alias used by some legacy paths — set to the same value as DISCORD_BOT_TOKEN

# ── Discord guild config (optional but recommended) ───────────
# When unset the bot derives the list from `client.guilds.cache` at
# runtime (any guild it's been invited to). Setting these explicitly
# pins the cross-guild fan-out (suspend / gban / role restore etc.)
# to a known set even if the bot is invited to extra unrelated guilds.
STAFF_HQ_ID=                # the primary staff guild (suspend / investigation roles apply here)
NETWORK_SERVER_IDS=         # comma-separated list of additional CO guilds (Staff HQ excluded)
APPEALS_SERVER_ID=          # the dedicated appeals guild — gunban DMs the user there
SUSPENDED_ROLE_ID=          # role applied by addSuspendedRole() on Staff HQ
UNDER_INVESTIGATION_ROLE_ID=# role applied by addInvestigationRole() on Staff HQ

# ── Permission grants (optional) ───────────────────────────────
# Comma-separated Discord IDs granted superuser access in addition to
# the hardcoded list in src/config.js.
SUPERUSER_IDS=

# ── Logging channels (optional — every category falls back to LOG_CHANNEL_ID
# if its specific channel is unset). See src/config/channels.js for the
# full list.
LOG_CHANNEL_ID=
COMMAND_LOG_CHANNEL_ID=
ANNOUNCEMENTS_CHANNEL_ID=

# ── Portal integration (required) ──────────────────────────────
PORTAL_URL=http://localhost:3016
PORTAL_DB_PATH=/path/to/onboarding-portal/data/onboarding.db
BOT_WEBHOOK_SECRET=         # shared secret, header `x-bot-secret` on portal API calls
PORT=3017                   # bot's HTTP webhook server port

# ── External APIs (optional) ───────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_API_KEY=
MINIMAX_API_KEY=
