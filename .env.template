# ─────────────────────────────────────────────────────────────────────────
# CO Discord Bot — environment template
# Copy to .env, fill in real values, then `pm2 restart 1 --update-env`.
# Variables marked [FATAL] cause the process to exit on startup if missing.
# Variables marked [SHARED-WITH-PORTAL] must match the portal's .env exactly.
# ─────────────────────────────────────────────────────────────────────────

# =========================================================================
# CORE — required
# =========================================================================

# [FATAL] Discord bot token. Get it from
#   https://discord.com/developers/applications → your app → Bot → Reset Token
DISCORD_BOT_TOKEN=

# [FATAL][SHARED-WITH-PORTAL] x-bot-secret header value validated on every
# inbound webhook from the portal. Process exits immediately if unset.
# Generate (in agreement with the portal) using:
#   openssl rand -hex 32
BOT_WEBHOOK_SECRET=

# [REQUIRED] Path to the portal's SQLite DB. Bot opens it READ-ONLY at
# import time (src/db.js); commands like /leaderboard, /aps, /cases query
# it directly. Must be the EXACT path the portal writes to.
PORTAL_DB_PATH=/home/vpcommunityorganisation/clawd/services/onboarding-portal/data/onboarding.db

NODE_ENV=production

# =========================================================================
# CROSS-SERVICE — bot ↔ portal HTTP
# =========================================================================

# Public-facing portal URL — used in DM links and Discord embeds.
PORTAL_URL=https://portal.communityorg.co.uk

# Internal portal API base — used for HTTP calls (assignments, cases,
# transcripts, activity sync, etc).
PORTAL_HTTP=http://localhost:3016

# Health-check endpoint. /ping uses this to measure portal latency.
PORTAL_HEALTH_URL=http://localhost:3016/api/health

# =========================================================================
# DISCORD IDs — find via Developer Mode → right-click → Copy ID
# =========================================================================

# Primary HQ guild — the bot only registers commands in guilds it's in,
# but anything cross-server uses these to scope behaviour.
STAFF_HQ_ID=

# Comma-separated guild IDs the bot considers part of the network
# (forced-verify, gban, gnick all scope to these).
NETWORK_SERVER_IDS=

# Role applied to suspended members in NETWORK_SERVER_IDS.
SUSPENDED_ROLE_ID=

# Role applied to members under investigation.
UNDER_INVESTIGATION_ROLE_ID=

# Guild that suspended users get DM'd a link to (appeals).
APPEALS_SERVER_ID=

# Channel IDs for log routing.
LOG_CHANNEL_ID=
COMMAND_LOG_CHANNEL_ID=
WELCOME_CHANNEL_ID=

# Comma-separated Discord user IDs that bypass all permission checks.
SUPERUSER_IDS=

# =========================================================================
# MICROSOFT 365 — optional, only needed for /audit-log + /m365 features
# =========================================================================
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# =========================================================================
# EMAIL — used by the bot's email-poller commands (/inbox, /compose)
# =========================================================================
# Brevo HTTP API key. Without it, /compose and /inbox-reply return errors.
BREVO_API_KEY=
