  "_field_guide": {
    "smtp_port": "587 = TLS, 465 = SSL, 25 = no encryption (not recommended)",
    "imap_port": "993 = IMAPS (SSL), 143 = IMAP (STARTTLS)",
    "imap_secure": "true for port 993, false for port 143",
    "smtp_secure": "true for port 465, false for port 587 (use STARTTLS)",
    "roleIds": "Find a Discord role ID by enabling Developer Mode → right-click role → Copy Role ID",
    "userIds": "Find a Discord user ID by enabling Developer Mode → right-click user → Copy User ID"
  }
}
