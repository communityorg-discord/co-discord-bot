      "emoji": "👥",
      "description": "HR Team Inbox",
      "smtp": {
        "host": "",
        "port": 587,
        "user": "",
        "password": "",
        "secure": false
      },
      "imap": {
        "host": "",
        "port": 993,
        "user": "",
        "password": "",
        "secure": true
      },
      "folders": {
        "inbox": "INBOX",
        "sent": "Sent",
        "archive": "Archive"
      },
      "access": {
        "_comment": "type 'role' restricts to specific Discord role IDs",
        "type": "role",
        "roleIds": [
          "DISCORD_ROLE_ID_HR_HERE"
        ]
      }
    },

    "it_support": {
      "_comment": "🖥️ IT support team only + EOB global viewer",
