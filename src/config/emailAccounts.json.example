{
  "_comment": "Rename this file to emailAccounts.json after filling in credentials",
  "_schema_version": "1.0",

  "inboxes": {
    "audit_vault": {
      "_comment": "🔐 RESTRICTED: Only these 3 IDs can access — no exceptions, no EOB",
      "id": "audit_vault",
      "name": "Audit Vault",
      "emoji": "🔐",
      "description": "Internal Audit and Compliance Inbox",
      "smtp": {
        "host": "smtp-mail.outlook.com",
        "port": 587,
        "user": "audit@yourdomain.com",
        "password": "YOUR_PASSWORD_HERE",
        "secure": false
      },
      "imap": {
        "host": "imap-mail.outlook.com",
        "port": 993,
        "user": "audit@yourdomain.com",
        "password": "YOUR_PASSWORD_HERE",
        "secure": true
      },
      "folders": {
        "inbox": "INBOX",
        "sent": "Sent",
        "archive": "Archive"
      },
      "access": {
        "_comment": "type must be 'ids' — EOB is explicitly blocked from this inbox",
        "type": "ids",
        "ids": [
          "723199054514749450",
          "415922272956710912",
          "1013486189891817563"
        ]
      }
    },

    "executive_operations": {
      "_comment": "🏛️ EOB global viewer — sees all inboxes EXCEPT Audit Vault",
      "id": "executive_operations",
      "name": "Executive Operations Board",
      "emoji": "🏛️",
      "description": "EOB Global Inbox — all team emails",
      "smtp": {
        "host": "smtp-mail.outlook.com",
        "port": 587,
        "user": "eob@yourdomain.com",
        "password": "YOUR_PASSWORD_HERE",
        "secure": false
      },
      "imap": {
        "host": "imap-mail.outlook.com",
        "port": 993,
        "user": "eob@yourdomain.com",
        "password": "YOUR_PASSWORD_HERE",
        "secure": true
      },
      "folders": {
        "inbox": "INBOX",
        "sent": "Sent",
        "archive": "Archive"
      },
      "access": {
        "_comment": "type 'eob' grants global viewer access to all non-audit_vault inboxes",
        "type": "eob",
        "_comment_roleIds": "Add Discord role IDs for EOB members here",
        "roleIds": [
          "DISCORD_ROLE_ID_EOB_HERE"
        ]
      }
    },

    "hr_department": {
      "_comment": "👥 HR team only + EOB global viewer",
